RunService.RenderStepped:Connect(function(dt)
    updateFovCircle()
    
    if rainbowFOVEnabled or rainbowTextEnabled then
        rainbowHue = (rainbowHue + dt * 0.5) % 1
        local rColor = Color3.fromHSV(rainbowHue, 1, 1)
        if rainbowFOVEnabled and fovCircle then fovCircle:FindFirstChildOfClass("UIStroke").Color = rColor end
        if rainbowTextEnabled then
            for _, obj in ipairs(frame:GetChildren()) do
                if obj:IsA("TextLabel") or (obj:IsA("TextButton") and obj ~= titleLabel) then obj.TextColor3 = rColor end
            end
        end
    end

    updateESP()
end)

