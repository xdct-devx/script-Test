    if not character then return end
    
    for _, skill in ipairs(_G.SelectedSkills) do
        if character:FindFirstChild("RemoteEvent") then
            character.RemoteEvent:FireServer(Enum.KeyCode[skill])
        end
        if character:FindFirstChild("LocalScript") and character.LocalScript:FindFirstChild("uhh") then
            character.LocalScript.uhh:FireServer(Enum.KeyCode[skill])
        end
    end
end

