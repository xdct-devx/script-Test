local function applyBulletTeleport(origin, targetPart)
    if not _G.BulletTP or not targetPart then return origin end
    return (targetPart.CFrame * CFrame.new(0, 0, 1)).p
end

if not oldNamecall then
    oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
        if checkcaller() then return oldNamecall(self, ...) end
        if not _G.SilentAim or not TargetPart or not CurrentTarget then
            return oldNamecall(self, ...)
        end

        local method = getnamecallmethod()
        local args   = {...}
        local argc   = select("#", ...)

        if (method == "FireServer" or method == "InvokeServer") and typeof(self) == "Instance" then
            local selfName = self.Name:lower()
            if selfName:match("fire") or selfName:match("hit") or selfName:match("attack") or selfName:match("damage") or selfName:match("shoot") or selfName:match("bullet") or selfName:match("projectile") or selfName:match("mouse") then
                if not ShouldHit() then 
                    return oldNamecall(self, ...) 
                end

                local modified = false
                for i = 1, argc do
                    local arg = args[i]
                    if typeof(arg) == "Vector3" then
                        args[i] = _G.BulletTP and applyBulletTeleport(arg, TargetPart) or TargetPart.Position
                        modified = true
                    elseif typeof(arg) == "CFrame" then
                        local origin = arg.Position
                        local targetPos = _G.BulletTP and applyBulletTeleport(origin, TargetPart) or TargetPart.Position
                        args[i] = CFrame.new(origin, targetPos)
                        modified = true
                    elseif typeof(arg) == "Ray" then
                        local origin = arg.Origin
                        local targetPos = _G.BulletTP and applyBulletTeleport(origin, TargetPart) or TargetPart.Position
                        args[i] = Ray.new(origin, (targetPos - origin).Unit * arg.Direction.Magnitude)
                        modified = true
                    end
                end

                if modified then 
                    return oldNamecall(self, unpack(args, 1, argc)) 
                end
            end
        end

        if method == "Raycast" and self == workspace then
            local origin    = args[1]
            local direction = args[2]
            if origin and TargetPart then
                if not ShouldHit() then 
                    return oldNamecall(self, ...) 
                end
                local targetPos = _G.BulletTP and applyBulletTeleport(origin, TargetPart) or TargetPart.Position
                local newDir    = (targetPos - origin).Unit * direction.Magnitude
                return oldNamecall(self, origin, newDir, args[3], args[4])
            end
        end

        if method:match("FindPartOnRay") and self == workspace then
            local ray = args[1]
            if ray and typeof(ray) == "Ray" and TargetPart then
                if not ShouldHit() then 
                    return oldNamecall(self, ...) 
                end
                local origin = ray.Origin
                local targetPos = _G.BulletTP and applyBulletTeleport(origin, TargetPart) or TargetPart.Position
                args[1] = Ray.new(origin, (targetPos - origin).Unit * ray.Direction.Magnitude)
                return oldNamecall(self, unpack(args, 1, argc))
            end
        end

        return oldNamecall(self, ...)
    end)
end

if not oldIndex then
    oldIndex = hookmetamethod(game, "__index", function(self, key)
        if checkcaller() then return oldIndex(self, key) end
        if self == Mouse and _G.SilentAim and TargetPart then
            local keyLower = tostring(key):lower()
            if keyLower == "hit" then
                if not ShouldHit() then return oldIndex(self, key) end
                local origin = Camera.CFrame.Position
                local targetPos = _G.BulletTP and applyBulletTeleport(origin, TargetPart) or TargetPart.Position
                return CFrame.new(targetPos)
            elseif keyLower == "target" then
                if not ShouldHit() then return oldIndex(self, key) end
                return TargetPart
            elseif keyLower == "unitray" then
                if not ShouldHit() then return oldIndex(self, key) end
                local origin = Camera.CFrame.Position
                local targetPos = _G.BulletTP and applyBulletTeleport(origin, TargetPart) or TargetPart.Position
                return Ray.new(origin, (targetPos - origin).Unit)
            end
        end
        return oldIndex(self, key)
    end)
end

